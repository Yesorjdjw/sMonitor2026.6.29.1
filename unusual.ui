  <property name="styleSheet">
   <string notr="true">
QWidget#unusual {
    background-color: #d6e8f5;
    border-radius: 16px;
    font-family: &quot;Helvetica Neue&quot;,&quot;PingFang SC&quot;,&quot;Microsoft YaHei&quot;,sans-serif;
}
QFrame#leftCard, QFrame#rightCard {
    background: #ffffff;
}
QWidget#leftTitleBar, QWidget#rightTitleBar {
    background-color: #1a7bbd;
}
QLabel#leftTitleText, QLabel#rightTitleText {
    color: #ffffff;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
    letter-spacing: 1px;
}
QLabel#countText {
    color: rgba(255,255,255,0.8);
    font-size: 12px;
    font-weight: 400;
    background: transparent;
}
QLabel#badgeTotal {
    background: #ff3b30;
    color: #ffffff;
    font-size: 12px;
    font-weight: bold;
    border-radius: 12px;
    padding: 2px 8px;
}
/* 分类按钮 - 默认态 */
QPushButton#catBtn1, QPushButton#catBtn2, QPushButton#catBtn3,
QPushButton#catBtn4, QPushButton#catBtn5 {
    background: transparent;
    border: none;
    border-radius: 0px;
    text-align: left;
    font-size: 13px;
    font-weight: 600;
    color: #333333;
    padding-left: 52px;
    padding-top: 6px;
}
QPushButton#catBtn1:hover, QPushButton#catBtn2:hover, QPushButton#catBtn3:hover,
QPushButton#catBtn4:hover, QPushButton#catBtn5:hover {
    background: #eef4fa;
}
    color: #888888;
    font-size: 11px;
    background: transparent;
}
/* 分类徽标 - 颜色在代码中设置，这里只定义样式基类 */
QLabel#badge1, QLabel#badge2 {
    background: #ff3b30;
    color: #ffffff;
    font-size: 11px;
    font-weight: bold;
    border-radius: 10px;
    padding: 1px 7px;
}
QLabel#badge3, QLabel#badge4 {
    background: #ff9500;
    color: #ffffff;
    font-size: 11px;
    font-weight: bold;
    border-radius: 10px;
    padding: 1px 7px;
}
QLabel#badge5 {
    background: #007aff;
    color: #ffffff;
    font-size: 11px;
    font-weight: bold;
    border-radius: 10px;
    padding: 1px 7px;
}
/* 指示色条 */
QLabel#ind1, QLabel#ind2 { background: #ff3b30; }
QLabel#ind3, QLabel#ind4 { background: #ff9500; }
QLabel#ind5 { background: #007aff; }
/* 表格 */
QHeaderView::section {
    background: #f2f4f7;
    color: #555555;
    font-size: 12px;
    font-weight: 600;
    border: none;
    border-bottom: 1px solid #e0e0e0;
    padding: 10px 8px;
}
QTableWidget#eventTable {
    background: #ffffff;
    border: none;
    font-size: 12px;
    color: #333333;
    gridline-color: #f0f0f0;
    selection-background-color: #e8f0fe;
}
QTableWidget#eventTable::item {
    padding: 8px;
    border-bottom: 1px solid #f0f0f0;
}
/* 返回按钮 - 简约线条风格 */
QPushButton#backBt {
    background: transparent;
    border: 1px solid rgba(26,123,189,0.25);
    border-radius: 14px;
    color: #1a7bbd;
    font-size: 12px;
    font-weight: 500;
    text-align: center;
}
QPushButton#backBt:hover {
    background: rgba(26,123,189,0.06);
    border-color: rgba(26,123,189,0.5);
}
