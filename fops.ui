    color: #999;
    font-size: 14px;
}
QListWidget#fileList {
    background: rgba(255,255,255,0.88);
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 12px;
    outline: none;
}
QListWidget#fileList::item {
    padding: 8px 10px;
    border-bottom: 1px solid #eee;
}
QListWidget#fileList::item:selected {
    background: #d6e8f5;
    color: #1a7bbd;
}
QPushButton#tabAll, QPushButton#tabPhoto, QPushButton#tabVideo {
    background: rgba(255,255,255,0.7);
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 12px;
    color: #555;
}
QPushButton#tabAll:checked, QPushButton#tabPhoto:checked, QPushButton#tabVideo:checked {
    background: #1a7bbd;
    color: #fff;
    border: none;
}
QPushButton#playBtn {
    background: #1a7bbd;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 12px;
}
QPushButton#playBtn:disabled {
    background: #bbb;
}
QPushButton#delBtn {
    background: #e74c3c;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 12px;
}
QPushButton#refreshBtn {
    background: rgba(255,255,255,0.9);
    color: #1a7bbd;
    border: 1px solid #1a7bbd;
    border-radius: 4px;
    font-size: 12px;
}
QPushButton#pushButton {
    background: rgba(255,255,255,0.9);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 20px;
    color: #1a7bbd;
    font-size: 13px;
    font-weight: 500;
}
